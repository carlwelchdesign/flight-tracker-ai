POSTGRES_DB=flight_tracker
POSTGRES_USER=flight_tracker
POSTGRES_PASSWORD=flight_tracker
POSTGRES_PORT=5433
API_PORT=8080
WEB_PORT=3001
APP_ENV=development
AUTH_MODE=development
OPERATIONS_MODE=simulation
INTERNAL_AUTH_SECRET=local-development-internal-auth-secret-change-me
INTERNAL_AUTH_KEY_ID=local-primary
# During a planned API-first rotation only; configure or remove this pair together.
# INTERNAL_AUTH_PREVIOUS_KEY_ID=local-previous
# INTERNAL_AUTH_PREVIOUS_SECRET=replace-with-the-prior-secret
AUTH_ASSERTION_ISSUER=flight-tracker-web
AUTH_ASSERTION_AUDIENCE=flight-tracker-api
DEV_AUTH_OPERATOR_ID=9c704a09-a62c-43d5-bac6-94ea2fd53b32
DEV_AUTH_OPERATOR_CODE=SIM
DEV_AUTH_OPERATOR_NAME=Simulation Operator
DEV_AUTH_TENANT_ID=local-flight-tracker
DEV_AUTH_SUBJECT=local-admin
DEV_AUTH_DISPLAY_NAME=Local Administrator
DEV_AUTH_ROLE=administrator
# Hosted web deployments use AUTH_MODE=clerk and also require Clerk publishable/secret keys.
ENABLE_REPLAY_CONTROLS=true
REPLAY_SCENARIO_PATH=/workspace/fixtures/replay/m1-operations-v1.json
# Hosted portfolio only: use with APP_ENV=production and AUTH_MODE=clerk.
ENABLE_PORTFOLIO_REPLAY=false
ENABLE_NOAA_WEATHER=false
NOAA_OPERATOR_ID=9c704a09-a62c-43d5-bac6-94ea2fd53b32
PUBLIC_WEATHER_OPERATOR_ID=9c704a09-a62c-43d5-bac6-94ea2fd53b32
NOAA_METAR_STATIONS=KSFO,KOAK,KSJC
NOAA_POLL_INTERVAL_SECONDS=60
NOAA_USER_AGENT=flight-tracker-ai/0.1 (+https://github.com/carlwelchdesign/flight-tracker-ai)
# NOAA_API_BASE_URL=https://aviationweather.gov/
ENABLE_ADSB_LOL_POSITIONS=false
ADSB_LOL_OPERATOR_ID=9c704a09-a62c-43d5-bac6-94ea2fd53b32
ADSB_LOL_LATITUDE=37.6213
ADSB_LOL_LONGITUDE=-122.3790
ADSB_LOL_RADIUS_NM=25
ADSB_LOL_POLL_INTERVAL_SECONDS=75
ADSB_LOL_USER_AGENT=flight-tracker-ai/0.1 (+https://github.com/carlwelchdesign/flight-tracker-ai)
# ADSB_LOL_API_BASE_URL=https://api.adsb.lol/
